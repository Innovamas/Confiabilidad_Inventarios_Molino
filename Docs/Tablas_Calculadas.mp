)<br>        ),<br><br>    "PEGAMENTO (Tote Comp.)",<br>        CALCULATE (<br>            MAX ( 'Registro de Inventarios'[PEGAMENTO (Tote Comp.) ] ),<br>            FILTER (<br>                'Registro de Inventarios',<br>                DATEVALUE ( 'Registro de Inventarios'[Fecha de Captura] ) = 'Calendario'[Date]<br>            )<br>        ),<br><br>    "PEGAMENTO (Tote Cm.)",<br>        CALCULATE (<br>            MAX ( 'Registro de Inventarios'[PEGAMENTO (Tote Cm.) ] ),<br>            FILTER (<br>                'Registro de Inventarios',<br>                DATEVALUE ( 'Registro de Inventarios'[Fecha de Captura] ) = 'Calendario'[Date]<br>            )<br>        ),<br><br>    "CARBONATO (Tarimas Completas)",<br>        CALCULATE (<br>            MAX ( 'Registro de Inventarios'[CARBONATO (Tarimas Completas) ] ),<br>            FILTER (<br>                'Registro de Inventarios',<br>                DATEVALUE ( 'Registro de Inventarios'[Fecha de Captura] ) = 'Calendario'[Date]<br>            )<br>        ),<br><br>    "CARBONATO (Costales)",<br>        CALCULATE (<br>            MAX ( 'Registro de Inventarios'[CARBONATO (Costales) ] ),<br>            FILTER (<br>                'Registro de Inventarios',<br>                DATEVALUE ( 'Registro de Inventarios'[Fecha de Captura] ) = 'Calendario'[Date]<br>            )<br>        ),<br><br>    "RC 8181 ( Tote Comp)",<br>        CALCULATE (<br>            MAX ( 'Registro de Inventarios'[RC 8181 ( Tote Comp) ] ),<br>            FILTER (<br>                'Registro de Inventarios',<br>                DATEVALUE ( 'Registro de Inventarios'[Fecha de Captura] ) = 'Calendario'[Date]<br>            )<br>        ),<br><br>    "RC 8181 (Tote Cm.)",<br>        CALCULATE (<br>            MAX ( 'Registro de Inventarios'[RC 8181 (Tote Cm.)] ),<br>            FILTER (<br>                'Registro de Inventarios',<br>                DATEVALUE ( 'Registro de Inventarios'[Fecha de Captura] ) = 'Calendario'[Date]<br>            )<b