                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                     |
| 96522   | Tabla_Encolante_Convertido                             | <br>ADDCOLUMNS (<br>    'Inventario Diario Limpio',<br><br>    "Kilos Encolante",<br>    VAR TotemComp = VALUE('Inventario Diario Limpio'[ENCOLANTE RC +SIZE 1225 ( Tote Comp.)])<br>    VAR TotemCm   = VALUE('Inventario Diario Limpio'[ENCOLANTE RC +SIZE 1225 ( Tote Cm.)])<br>    VAR SiloCm    = VALUE('Inventario Diario Limpio'[ENCOLANTE RC +SIZE 1225 ( Silo Cm.)])<br><br>    VAR Mult_TotemComp =<br>        VALUE (<br>            CALCULATE (<br>                MAX ( 'Tabla de Conversión'[Valor Unitario] ),<br>                FILTER (<br>                    ALL ( 'Tabla de Conversión' ),<br>                    SEARCH (<br>                        "ENCOLANTE RC +SIZE 1225 ( Tote Comp.)",<br>                        TRIM ( 'Tabla de Conversión'[Tipo de Material] ),<br>                        1,<br>                        0<br>                    ) > 0<br>                )<br>            )<br>        )<br><br>    VAR Mult_TotemCm =<br>        VALUE (<br>            CALCULATE (<br>                MAX ( 'Tabla de Conversión'[Valor Unitario] ),<br>                FILTER (<br>                    ALL ( 'Tabla de Conversión' ),<br>                    SEARCH (<br>                        "ENCOLANTE RC +SIZE 1225 ( Tote Cm.)",<br>                        TRIM ( 'Tabla de Conversión'[Tipo de Material] ),<br>                        1,<br>                        0<br>                    ) > 0<br>                )<br>            )<br>        )<br><br>    VAR Mult_SiloCm =<br>        VALUE (<br>            CALCULATE (<br>                MAX ( 'Tabla de Conversión'[Valor Unitario] ),<br>                FILTER (<br>                    ALL ( 'Tabla de Conversión' ),<br>                    SEARCH (<br>                        "ENCOLANTE RC +SIZE 1225 ( Silo Cm.)",<br>                        TRIM ( 'Tabla de Conversión'[Tipo de Material] ),<br>                        1,<br>                        0<br>                    ) > 0<br>                )<br>            )<br>        )<br><br>    RETURN<br>        COALESCE ( TotemComp, 0 ) \* COALESCE ( Mult_TotemComp, 0 )<br>        + COALESCE ( TotemCm, 0 ) \* COALESCE ( Mult_TotemCm, 0 )<br>        + COALESCE ( SiloCm, 0 ) \* COALESCE ( Mult_SiloCm, 0 )<br>)<br>                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                   