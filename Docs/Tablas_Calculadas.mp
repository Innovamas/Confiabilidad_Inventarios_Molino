| 63227   | Inventario Diario Limpio                               | <br>VAR Fechas =<br>    FILTER (<br>        'Calendario',<br>        'Calendario'[Date] >= DATE(2026, 1, 1)<br>            && 'Calendario'[Date] < DATE(2036, 1, 11)<br>    )<br><br>RETURN<br>ADDCOLUMNS (<br>    Fechas,<br><br>    "Fecha de Captura",<br>        CALCULATE (<br>            MAX ( 'Registro de Inventarios'[Fecha de Captura] ),<br>            FILTER (<br>                'Registro de Inventarios',<br>                DATEVALUE ( 'Registro de Inventarios'[Fecha de Captura] ) = 'Calendario'[Date]<br>            )<br>        ),<br><br>    "ENCOLANTE RC +SIZE 1225 ( Tote Comp.)",<br>        CALCULATE (<br>            MAX ( 'Registro de Inventarios'[ENCOLANTE RC +SIZE 1225 ( Tote Comp.) ] ),<br>            FILTER (<br>                'Registro de Inventarios',<br>                DATEVALUE ( 'Registro de Inventarios'[Fecha de Captura] ) = 'Calendario'[Date]<br>            )<br>        ),<br><br>    "ENCOLANTE RC +SIZE 1225 ( Tote Cm.)",<br>        CALCULATE (<br>            MAX ( 'Registro de Inventarios'[ENCOLANTE RC +SIZE 1225 ( Tote Cm.) ] ),<br>            FILTER (<br>                'Registro de Inventarios',<br>                DATEVALUE ( 'Registro de Inventarios'[Fecha de Captura] ) = 'Calendario'[Date]<br>            )<br>        ),<br><br>    "ENCOLANTE RC +SIZE 1225 ( Silo Cm.)",<br>        CALCULATE (<br>            MAX ( 'Registro de Inventarios'[ENCOLANTE RC +SIZE 1225 ( Silo Cm.) ] ),<br>            FILTER (<br>                'Registro de Inventarios',<br>                DATEVALUE ( 'Registro de Inventarios'[Fecha de Captura] ) = 'Calendario'[Date]<br>            )<br>        ),<br><br>    "BARRERADOR RC + SP 2050 (Tote Comp.)",<br>        CALCULATE (<br>            MAX ( 'Registro de Inventarios'[BARRERADOR RC + SP 2050 (Tote Comp.) ] ),<br>            FILTER (<br>                'Registro de Inventarios',<br>                DATEVALUE ( 'Registro de Inventarios'[Fecha de Captura] ) = 'Calendario'[Date]<br>            )<br>        ),<br><br>    "BARRERADOR RC + SP 2050 (Tote Diluido)",<br>        CALCULATE (<br>            MAX ( 'Registro de Inventarios'[BARRERADOR RC + SP 2050 (Tote Diluido)] ),<br>            FILTER (<br>                'Registro de Inventarios',<br>                DATEVALUE ( 'Registro de Inventarios'[Fecha de Captura] ) = 'Calendario'[Date]<br>            )<br>        ),<br><br>    "BARRERADOR RC + SP 2050 (Tote Cm.)",<br>        CALCULATE (<br>            MAX ( 'Registro de Inventarios'[BARRERADOR RC + SP 2050 (Tote Cm.) ] ),<br>            FILTER (<br>                'Registro de Inventarios',<br>                DATEVALUE ( 'Registro de Inventarios'[Fecha de Captura] ) = 'Calendario'[Date]<br>            )<br>        ),<br><br>    "RETENTIVO RC + FLOCDREN 6226 (Costal)",<br>        CALCULATE (<br>            MAX ( 'Registro de Inventarios'[RETENTIVO RC + FLOCDREN 6226 (Costal) ] ),<br>            FILTER (<br>                'Registro de Inventarios',<br>                DATEVALUE ( 'Registro de Inventarios'[Fecha de Captura] ) = 'Calendario'[Date]<br>            )<br>        ),<br><br>    "RETENTIVO RC + FLOCDREN 6226 (Tarima)",<br>        CALCULATE (<br>            MAX ( 'Registro de Inventarios'[RETENTIVO RC + FLOCDREN 6226 (Tarima) ] ),<br>            FILTER (<br>                'Registro de Inventarios',<br>                DATEVALUE ( 'Registro de Inventarios'[Fecha de Captura] ) = 'Calendario'[Date]<br>            )<br>        ),<br><br>    "RC + OBA 1540 (Tote Comp.)",<br>        CALCULATE (<br>            MAX ( 'Registro de Inventarios'[RC + OBA 1540 (Tote Comp.) ] ),<br>            FILTER (<br>                'Registro de Inventarios',<br>                DATEVALUE ( 'Registro de Inventarios'[Fecha de Captura] ) = 'Calendario'[Date]<br>            )<br>        ),<br><br>    "RC + OBA 1540 (Tote Cm.)",<br>        CALCULATE (<br>            MAX ( 'Registro de Inventarios'[RC + OBA 1540 (Tote Cm.) ] ),<br>          