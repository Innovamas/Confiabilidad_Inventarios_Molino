| NAME                        | Expression                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                           |
| --------------------------- | -------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------- |
| Fecha Último Registro       | <br>CALCULATE (<br>    MAX ( 'Tabla_Encolante_Convertido'[Date] ),<br>    FILTER (<br>        'Tabla_Encolante_Convertido',<br>        [Kilos Encolante] > 1 \|\|<br>        [Kilos Barrerador] > 1 \|\|<br>        [Kilos Retentivo 6226] > 1 \|\|<br>        [Kilos OBA 1540] > 1 \|\|<br>        [Kilos BLEACH] > 1 \|\|<br>        [Kilos Fixer 2960] > 1 \|\|<br>        [Kilos Almidón de Maíz] > 1 \|\|<br>        [Kilos Coagulante] > 1 \|\|<br>        [Kilos Clean 2000] > 1 \|\|<br>        [Kilos FLOC 61100] > 1 \|\|<br>        [Kilos Pegamento] > 1 \|\|<br>        [Kilos Carbonato] > 1 \|\|<br>        [Kilos RC 8181] > 1<br>    )<br>)<br><br> |
| Total Registros             | <br>COUNTROWS('Confiabilidad de Inventarios')<br>                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    |
| Cumplen 100%                | <br>VAR TotalCumplen =<br>    CALCULATE(<br>        COUNTROWS('Confiabilidad de Inventarios'),<br>        'Confiabilidad de Inventarios'[Confiabilidad 100%] = "CUMPLE"<br>    )<br>RETURN<br>    COALESCE(TotalCumplen, 0)<br><br>                                                                                                                                                                                                                                                                                                                                                                                                                                  |
| PorcentajeCumplimiento100   | <br>DIVIDE(<br>    [Cumplen 100%],<br>    [Total Registros],<br>    0<br>)<br><br>                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                   |
| Cumplen 90%                 | <br>CALCULATE(<br>    COUNTROWS('Confiabilidad de Inventarios'),<br>    'Confiabilidad de Inventarios'[Confiabilidad 90%] = "CUMPLE"<br>)<br>                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        |
| % Cumplimiento 90%          | <br>VAR TotalRegistros =<br>    COUNTROWS('Confiabilidad de Inventarios')<br><br>VAR TotalCumplen =<br>    CALCULATE(<br>        COUNTROWS('Confiabilidad de Inventarios'),<br>        'Confiabilidad de Inventarios'[Confiabilidad 90%] = "CUMPLE"<br>    )<br><br>RETURN<br>    DIVIDE(TotalCumplen, TotalRegistros, 0)<br>                                                                                                                                                                                                                                                                                                                                        |
| Cumplen 95%                 | <br>COALESCE(<br>    CALCULATE(<br>        COUNTROWS('Confiabilidad de Inventarios'),<br>        'Confiabilidad de Inventarios'[Confiabilidad 95%] = "CUMPLE"<br>    ),<br>    0<br>)<br>                                                                                                                                                                                                                                                                                                                                                                                                                                                                            |
| % Cumplimiento 95%          | <br>VAR TotalRegistros =<br>    CALCULATE(<br>        COUNTROWS('Confiabilidad de Inventarios'),<br>        ALL('Confiabilidad de Inventarios'[Descripción del Material])<br>    )<br><br>VAR TotalCumplen =<br>    CALCULATE(<br>        COUNTROWS('Confiabilidad de Inventarios'),<br>        'Confiabilidad de Inventarios'[Confiabilidad 95%] = "CUMPLE",<br>        ALL('Confiabilidad de Inventarios'[Descripción del Material])<br>    )<br><br>RETURN<br>DIVIDE(TotalCumplen, TotalRegistros, 0)<br>                                                                                                                                                         |
| % Cumplimiento 100%         | <br>VAR TotalRegistros =<br>    CALCULATE(<br>        COUNTROWS('Confiabilidad de Inventarios'),<br>        ALL('Confiabilidad de Inventarios'[Descripción del Material])<br>    )<br><br>VAR TotalCumplen =<br>    CALCULATE(<br>        COUNTROWS('Confiabilidad de Inventarios'),<br>        'Confiabilidad de Inventarios'[Confiabilidad 100%] = "CUMPLE",<br>        ALL('Confiabilidad de Inventarios'[Descripción del Material])<br>    )<br><br>RETURN<br>DIVIDE(TotalCumplen, TotalRegistros, 0)<br><br>                                                                                                                                                    |
| Promedio % de Confiabilidad | <br>AVERAGEX(<br>    FILTER(<br>        'Confiabilidad de Inventarios',<br>        NOT ISBLANK('Confiabilidad de Inventarios'[% de Confiabilidad])<br>    ),<br>    'Confiabilidad de Inventarios'[% de Confiabilidad]<br>)<br>                                                                                                                                                                                                                                                                                                                                                                                                                                      |
