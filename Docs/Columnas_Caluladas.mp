| Column Name                    | Expression                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                         |
| ------------------------------ | -------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------- |
| Kilos Barrerador               | <br>VAR TotemComp = VALUE('Tabla_Encolante_Convertido'[BARRERADOR RC + SP 2050 (Tote Comp.)])<br>VAR TotemDiluido = VALUE('Tabla_Encolante_Convertido'[BARRERADOR RC + SP 2050 (Tote Diluido)])<br>VAR TotemCm = VALUE('Tabla_Encolante_Convertido'[BARRERADOR RC + SP 2050 (Tote Cm.)])<br><br>VAR Mult_TotemComp =<br>    VALUE (<br>        CALCULATE (<br>            MAX ( 'Tabla de Conversión'[Valor Unitario] ),<br>            FILTER (<br>                ALL ( 'Tabla de Conversión' ),<br>                SEARCH (<br>                    "BARRERADOR RC + SP 2050 (Tote Comp.)",<br>                    TRIM ( 'Tabla de Conversión'[Tipo de Material] ),<br>                    1,<br>                    0<br>                ) > 0<br>            )<br>        )<br>    )<br><br>VAR Mult_TotemDiluido =<br>    VALUE (<br>        CALCULATE (<br>            MAX ( 'Tabla de Conversión'[Valor Unitario] ),<br>            FILTER (<br>                ALL ( 'Tabla de Conversión' ),<br>                SEARCH (<br>                    "BARRERADOR RC + SP 2050 (Tote Diluido)",<br>                    TRIM ( 'Tabla de Conversión'[Tipo de Material] ),<br>                    1,<br>                    0<br>                ) > 0<br>            )<br>        )<br>    )<br><br>VAR Mult_TotemCm =<br>    VALUE (<br>        CALCULATE (<br>            MAX ( 'Tabla de Conversión'[Valor Unitario] ),<br>            FILTER (<br>                ALL ( 'Tabla de Conversión' ),<br>                SEARCH (<br>                    "BARRERADOR RC + SP 2050 (Totem Cm.)",<br>                    TRIM ( 'Tabla de Conversión'[Tipo de Material] ),<br>                    1,<br>                    0<br>                ) > 0<br>            )<br>        )<br>    )<br><br>RETURN<br>    COALESCE ( TotemComp, 0 ) \* COALESCE ( Mult_TotemComp, 0 ) +<br>    COALESCE ( TotemDiluido, 0 ) \* COALESCE ( Mult_TotemDiluido, 0 ) +<br>    COALESCE ( TotemCm, 0 ) \* COALESCE ( Mult_TotemCm, 0 )<br>                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                     |
| Kilos Retentivo 6226           | <br>VAR CantidadCostal = VALUE('Tabla_Encolante_Convertido'[RETENTIVO RC + FLOCDREN 6226 (Costal)])<br>VAR CantidadTarima = VALUE('Tabla_Encolante_Convertido'[RETENTIVO RC + FLOCDREN 6226 (Tarima)])<br><br>VAR MultiplicadorCostal =<br>    VALUE (<br>        CALCULATE (<br>            MAX ( 'Tabla de Conversión'[Valor Unitario] ),<br>            FILTER (<br>                ALL ( 'Tabla de Conversión' ),<br>                SEARCH (<br>                    "RETENTIVO RC + FLOCDREN 6226 (Costal)",<br>                    TRIM ( 'Tabla de Conversión'[Tipo de Material] ),<br>                    1, 0<br>                ) > 0<br>            )<br>        )<br>    )<br><br>VAR MultiplicadorTarima =<br>    VALUE (<br>        CALCULATE (<br>            MAX ( 'Tabla de Conversión'[Valor Unitario] ),<br>            FILTER (<br>                ALL ( 'Tabla de Conversión' ),<br>                SEARCH (<br>                    "RETENTIVO RC + FLOCDREN 6226 (Tarima)",<br>                    TRIM ( 'Tabla de Conversión'[Tipo de Material] ),<br>                    1, 0<br>                ) > 0<br>            )<br>        )<br>    )<br><br>RETURN<br>    COALESCE(CantidadCostal, 0) \* COALESCE(MultiplicadorCostal, 0) +<br>    COALESCE(CantidadTarima, 0) \* COALESCE(MultiplicadorTarima, 0)<br>                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                           |
| Kilos OBA 1540                 | <br>VAR TotemComp = VALUE('Tabla_Encolante_Convertido'[RC + OBA 1540 (Tote Comp.)])<br>VAR TotemCm   = VALUE('Tabla_Encolante_Convertido'[RC + OBA 1540 (Tote Cm.)])<br><br>VAR Mult_TotemComp =<br>    VALUE (<br>        CALCULATE (<br>            MAX ( 'Tabla de Conversión'[Valor Unitario] ),<br>            FILTER (<br>                ALL ( 'Tabla de Conversión' ),<br>                SEARCH (<br>                    "RC + OBA 1540 (Tote Comp.)",<br>                    TRIM ( 'Tabla de Conversión'[Tipo de Material] ),<br>                    1,<br>                    0<br>                ) > 0<br>            )<br>        )<br>    )<br><br>VAR Mult_TotemCm =<br>    VALUE (<br>        CALCULATE (<br>            MAX ( 'Tabla de Conversión'[Valor Unitario] ),<br>            FILTER (<br>                ALL ( 'Tabla de Conversión' ),<br>                SEARCH (<br>                    "RC + OBA 1540 (Tote Cm.)",<br>                    TRIM ( 'Tabla de Conversión'[Tipo de Material] ),<br>                    1,<br>                    0<br>                ) > 0<br>            )<br>        )<br>    )<br><br>RETURN<br>    COALESCE(TotemComp, 0) \* COALESCE(Mult_TotemComp, 0) +<br>    COALESCE(TotemCm, 0) \* COALESCE(Mult_TotemCm, 0)<br>                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                           |
| Kilos BLEACH                   | <br>VAR TotemCompleto = VALUE('Tabla_Encolante_Convertido'[RC+BLEACH 3006 (Tote Completo)])<br>VAR TotemCm       = VALUE('Tabla_Encolante_Convertido'[RC+BLEACH 3006 (Tote Cm.)])<br><br>VAR Mult_TotemCompleto =<br>    VALUE (<br>        CALCULATE (<br>            MAX ( 'Tabla de Conversión'[Valor Unitario] ),<br>            FILTER (<br>                ALL ( 'Tabla de Conversión' ),<br>                SEARCH (<br>                    "RC+BLEACH 3006 (Tote Completo)",<br>                    TRIM ( 'Tabla de Conversión'[Tipo de Material] ),<br>                    1,<br>                    0<br>                ) > 0<br>            )<br>        )<br>    )<br><br>VAR Mult_TotemCm =<br>    VALUE (<br>        CALCULATE (<br>            MAX ( 'Tabla de Conversión'[Valor Unitario] ),<br>            FILTER (<br>                ALL ( 'Tabla de Conversión' ),<br>                SEARCH (<br>                    "RC+BLEACH 3006 (Tote Cm.)",<br>                    TRIM ( 'Tabla de Conversión'[Tipo de Material] ),<br>                    1,<br>                    0<br>                ) > 0<br>            )<br>        )<br>    )<br><br>RETURN<br>    COALESCE(TotemCompleto, 0) \* COALESCE(Mult_TotemCompleto, 0) +<br>    COALESCE(TotemCm, 0) \* COALESCE(Mult_TotemCm, 0)<br>                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                             |
| Kilos Fixer 2960               | <br>VAR Cantidad =<br>    VALUE ( 'Tabla_Encolante_Convertido'[RC + FIXER 2960 ( Costal)] )<br><br>VAR Multiplicador =<br>    VALUE (<br>        CALCULATE (<br>            MAX ( 'Tabla de Conversión'[Valor Unitario] ),<br>            FILTER (<br>                ALL ( 'Tabla de Conversión' ),<br>                SEARCH (<br>                    "RC + FIXER 2960 ( Costal)",<br>                    TRIM ( 'Tabla de Conversión'[Tipo de Material] ),<br>                    1,<br>                    0<br>                ) > 0<br>            )<br>        )<br>    )<br><br>RETURN<br>    COALESCE ( Cantidad, 0 ) \* COALESCE ( Multiplicador, 0 )<br>                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                |
| Kilos Almidón de Maíz          | <br>VAR Tarimas = VALUE('Tabla_Encolante_Convertido'[ALMIDON DE MAIZ ( Tarimas Completas)])<br>VAR Costal  = VALUE('Tabla_Encolante_Convertido'[ALMIDON DE MAIZ ( Costal)])<br><br>VAR Mult_Tarimas =<br>    VALUE (<br>        CALCULATE (<br>            MAX('Tabla de Conversión'[Valor Unitario]),<br>            FILTER (<br>                ALL('Tabla de Conversión'),<br>                SEARCH("ALMIDON DE MAIZ ( Tarimas Completas)", TRIM('Tabla de Conversión'[Tipo de Material]), 1, 0) > 0<br>            )<br>        )<br>    )<br><br>VAR Mult_Costal =<br>    VALUE (<br>        CALCULATE (<br>            MAX('Tabla de Conversión'[Valor Unitario]),<br>            FILTER (<br>                ALL('Tabla de Conversión'),<br>                SEARCH("ALMIDON DE MAIZ ( Costal)", TRIM('Tabla de Conversión'[Tipo de Material]), 1, 0) > 0<br>            )<br>        )<br>    )<br><br>RETURN<br>    COALESCE(Tarimas, 0) \* COALESCE(Mult_Tarimas, 0) +<br>    COALESCE(Costal, 0) \* COALESCE(Mult_Costal, 0)<br>                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        |
| Kilos Coagulante               | <br>VAR TotemComp = VALUE('Tabla_Encolante_Convertido'[COAGULANTE RC + CAT 1200 NF (Tote Comp.)])<br>VAR TotemCm   = VALUE('Tabla_Encolante_Convertido'[COAGULANTE RC + CAT 1200 NF (Tote Cm.)])<br><br>VAR Mult_TotemComp =<br>    VALUE (<br>        CALCULATE (<br>            MAX('Tabla de Conversión'[Valor Unitario]),<br>            FILTER (<br>                ALL('Tabla de Conversión'),<br>                SEARCH("COAGULANTE RC + CAT 1200 NF (Tote Comp.)", TRIM('Tabla de Conversión'[Tipo de Material]), 1, 0) > 0<br>            )<br>        )<br>    )<br><br>VAR Mult_TotemCm =<br>    VALUE (<br>        CALCULATE (<br>            MAX('Tabla de Conversión'[Valor Unitario]),<br>            FILTER (<br>                ALL('Tabla de Conversión'),<br>                SEARCH("COAGULANTE RC + CAT 1200 NF (Tote Cm.)", TRIM('Tabla de Conversión'[Tipo de Material]), 1, 0) > 0<br>            )<br>        )<br>    )<br><br>RETURN<br>    COALESCE(TotemComp, 0) \* COALESCE(Mult_TotemComp, 0) +<br>    COALESCE(TotemCm, 0) \* COALESCE(Mult_TotemCm, 0)<br>                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                         |
| Kilos Clean 2000               | <br>VAR Garrafa = VALUE('Tabla_Encolante_Convertido'[CLEAN2000 (Garrafa)])<br><br>VAR Mult_Garrafa =<br>    VALUE (<br>        CALCULATE (<br>            MAX('Tabla de Conversión'[Valor Unitario]),<br>            FILTER (<br>                ALL('Tabla de Conversión'),<br>                SEARCH("CLEAN2000 (Garrafa)", TRIM('Tabla de Conversión'[Tipo de Material]), 1, 0) > 0<br>            )<br>        )<br>    )<br><br>RETURN<br>    COALESCE(Garrafa, 0) \* COALESCE(Mult_Garrafa, 0)<br>                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                           |
| Kilos FLOC 61100               | <br>VAR Tarimas = VALUE('Tabla_Encolante_Convertido'[RC + FLOC 61100 (Tarimas Completas)])<br>VAR Costal  = VALUE('Tabla_Encolante_Convertido'[RC + FLOC 61100 (Costal)])<br><br>VAR Mult_Tarimas =<br>    VALUE (<br>        CALCULATE (<br>            MAX('Tabla de Conversión'[Valor Unitario]),<br>            FILTER (<br>                ALL('Tabla de Conversión'),<br>                SEARCH("RC + FLOC 61100 (Tarimas Completas)", TRIM('Tabla de Conversión'[Tipo de Material]), 1, 0) > 0<br>            )<br>        )<br>    )<br><br>VAR Mult_Costal =<br>    VALUE (<br>        CALCULATE (<br>            MAX('Tabla de Conversión'[Valor Unitario]),<br>            FILTER (<br>                ALL('Tabla de Conversión'),<br>                SEARCH("RC + FLOC 61100 (Costal)", TRIM('Tabla de Conversión'[Tipo de Material]), 1, 0) > 0<br>            )<br>        )<br>    )<br><br>RETURN<br>    COALESCE(Tarimas, 0) \* COALESCE(Mult_Tarimas, 0) +<br>    COALESCE(Costal, 0) \* COALESCE(Mult_Costal, 0)<br>                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            |
| Kilos Pegamento                | <br>VAR TotemComp = VALUE('Tabla_Encolante_Convertido'[PEGAMENTO (Tote Comp.)])<br>VAR TotemCm   = VALUE('Tabla_Encolante_Convertido'[PEGAMENTO (Tote Cm.)])<br><br>VAR Mult_TotemComp =<br>    VALUE (<br>        CALCULATE (<br>            MAX('Tabla de Conversión'[Valor Unitario]),<br>            FILTER (<br>                ALL('Tabla de Conversión'),<br>                SEARCH("PEGAMENTO (Tote Comp.)", TRIM('Tabla de Conversión'[Tipo de Material]), 1, 0) > 0<br>            )<br>        )<br>    )<br><br>VAR Mult_TotemCm =<br>    VALUE (<br>        CALCULATE (<br>            MAX('Tabla de Conversión'[Valor Unitario]),<br>            FILTER (<br>                ALL('Tabla de Conversión'),<br>                SEARCH("PEGAMENTO (Tote Cm.)", TRIM('Tabla de Conversión'[Tipo de Material]), 1, 0) > 0<br>            )<br>        )<br>    )<br><br>RETURN<br>    COALESCE(TotemComp, 0) \* COALESCE(Mult_TotemComp, 0) +<br>    COALESCE(TotemCm, 0) \* COALESCE(Mult_TotemCm, 0)<br>                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                 |
| Kilos Carbonato                | <br>VAR Tarimas  = VALUE('Tabla_Encolante_Convertido'[CARBONATO (Tarimas Completas)])<br>VAR Costales = VALUE('Tabla_Encolante_Convertido'[CARBONATO (Costales)])<br><br>VAR Mult_Tarimas =<br>    VALUE (<br>        CALCULATE (<br>            MAX('Tabla de Conversión'[Valor Unitario]),<br>            FILTER (<br>                ALL('Tabla de Conversión'),<br>                SEARCH("CARBONATO (Tarimas Completas)", TRIM('Tabla de Conversión'[Tipo de Material]), 1, 0) > 0<br>            )<br>        )<br>    )<br><br>VAR Mult_Costales =<br>    VALUE (<br>        CALCULATE (<br>            MAX('Tabla de Conversión'[Valor Unitario]),<br>            FILTER (<br>                ALL('Tabla de Conversión'),<br>                SEARCH("CARBONATO (Costales)", TRIM('Tabla de Conversión'[Tipo de Material]), 1, 0) > 0<br>            )<br>        )<br>    )<br><br>RETURN<br>    COALESCE(Tarimas, 0) \* COALESCE(Mult_Tarimas, 0) +<br>    COALESCE(Costales, 0) \* COALESCE(Mult_Costales, 0)<br>                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        |
| Kilos RC 8181                  | <br>VAR TotemComp = VALUE('Tabla_Encolante_Convertido'[RC 8181 ( Tote Comp)])<br>VAR TotemCm   = VALUE('Tabla_Encolante_Convertido'[RC 8181 (Tote Cm.)])<br><br>VAR Mult_TotemComp =<br>    VALUE (<br>        CALCULATE (<br>            MAX('Tabla de Conversión'[Valor Unitario]),<br>            FILTER (<br>                ALL('Tabla de Conversión'),<br>                SEARCH("RC 8181 ( Tote Comp)", TRIM('Tabla de Conversión'[Tipo de Material]), 1, 0) > 0<br>            )<br>        )<br>    )<br><br>VAR Mult_TotemCm =<br>    VALUE (<br>        CALCULATE (<br>            MAX('Tabla de Conversión'[Valor Unitario]),<br>            FILTER (<br>                ALL('Tabla de Conversión'),<br>                SEARCH("RC 8181 (Tote Cm.)", TRIM('Tabla de Conversión'[Tipo de Material]), 1, 0) > 0<br>            )<br>        )<br>    )<br><br>RETURN<br>    COALESCE(TotemComp, 0) \* COALESCE(Mult_TotemComp, 0) +<br>    COALESCE(TotemCm, 0) \* COALESCE(Mult_TotemCm, 0)<br>                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                         |
| Kilos NUEVO MATERIAL (EJEMPLO) | <br>\-- 🌐 PLANTILLA PARA AGREGAR NUEVOS MATERIALES<br>\-- Esta columna está desactivada por defecto. NO genera valores hasta que sea activada manualmente.<br>\-- Sirve como guía para añadir nuevos materiales con conversión a kilos, igual que el resto del modelo.<br><br>\-- 👇 ¿CÓMO USAR ESTA PLANTILLA?<br><br>\-- 1. Ubica el nombre del nuevo material (por ejemplo, "AGENTE XYZ (Costal)")<br>\-- 2. Confirma que ese nombre aparece en la tabla 'Tabla de Conversión' dentro de [Tipo de Material],<br>\--    y que tiene un [Valor Unitario] asignado (ej. 25 kg por costal).<br>\-- 3. Reemplaza las variables 'Presentacion1' y 'Presentacion2' por los nombres REALES de columna en esta tabla.<br>\-- 4. Si solo hay una presentación, puedes borrar o comentar la segunda.<br>\-- 5. Si tienes dudas, copia todo este bloque y consulta directamente en ChatGPT.<br>\--    🧠 Consejo: Pega la fórmula completa y pregunta algo como:<br>\--    “Hola ChatGPT, quiero activar esta plantilla para un nuevo material que se llama X,<br>\--     ¿me ayudas a ajustarla con las columnas reales?”<br><br>\-- ---------------------------------------------<br>\-- ✏️ ACTIVAR Y AJUSTAR AQUI ABAJO:<br>\-- ---------------------------------------------<br><br>\-- VAR Presentacion1 = VALUE('Tabla_Encolante_Convertido'[NUEVO MATERIAL (Presentación X)])     -- ACTIVAR<br>\-- VAR Presentacion2 = VALUE('Tabla_Encolante_Convertido'[NUEVO MATERIAL (Presentación Y)])     -- ACTIVAR<br><br>\-- VAR Mult_Presentacion1 =                                                                      -- ACTIVAR<br>\--     VALUE (                                                                                   -- ACTIVAR<br>\--         CALCULATE (                                                                           -- ACTIVAR<br>\--             MAX('Tabla de Conversión'[Valor Unitario]),                                       -- ACTIVAR<br>\--             FILTER (                                                                          -- ACTIVAR<br>\--                 ALL('Tabla de Conversión'),                                                   -- ACTIVAR<br>\--                 SEARCH("NUEVO MATERIAL (Presentación X)",                                     -- ACTIVAR<br>\--                        TRIM('Tabla de Conversión'[Tipo de Material]), 1, 0) > 0               -- ACTIVAR<br>\--             )                                                                                 -- ACTIVAR<br>\--         )                                                                                     -- ACTIVAR<br>\--     )                                                                                         -- ACTIVAR<br><br>\-- VAR Mult_Presentacion2 =                                                                      -- ACTIVAR<br>\--     VALUE (                                                                                   -- ACTIVAR<br>\--         CALCULATE (                                                                           -- ACTIVAR<br>\--             MAX('Tabla de Conversión'[Valor Unitario]),                                       -- ACTIVAR<br>\--             FILTER (                                                                          -- ACTIVAR<br>\--                 ALL('Tabla de Conversión'),                                                   -- ACTIVAR<br>\--                 SEARCH("NUEVO MATERIAL (Presentación Y)",                                     -- ACTIVAR<br>\--                        TRIM('Tabla de Conversión'[Tipo de Material]), 1, 0) > 0               -- ACTIVAR<br>\--             )                                                                                 -- ACTIVAR<br>\--         )                                                                                     -- ACTIVAR<br>\--     )                                                                                         -- ACTIVAR<br><br>\-- RETURN                                                                                        -- ACTIVAR<br>\--     COALESCE(Presentacion1, 0) \* COALESCE(Mult_Presentacion1, 0) +                             -- ACTIVAR<br>\--     COALESCE(Presentacion2, 0) \* COALESCE(Mult_Presentacion2, 0)                               -- ACTIVAR<br><br>\--RETURN<br>    BLANK() -- Esta línea mantiene la columna en blanco hasta que se active.<br>    |
| Kilos Fixer 2020               | <br>VAR Cantidad =<br>    VALUE ( 'Tabla_Encolante_Convertido'[RC + FIXER 2020 ( Garrafa)] )<br><br>VAR Multiplicador =<br>    VALUE (<br>        CALCULATE (<br>            MAX ( 'Tabla de Conversión'[Valor Unitario] ),<br>            FILTER (<br>                ALL ( 'Tabla de Conversión' ),<br>                SEARCH (<br>                    "RC + FIXER 2020 ( Garrafa)",<br>                    TRIM ( 'Tabla de Conversión'[Tipo de Material] ),<br>                    1,<br>                    0<br>                ) > 0<br>            )<br>        )<br>    )<br><br>RETURN<br>    COALESCE ( Cantidad, 0 ) \* COALESCE ( Multiplicador, 0 )<br>                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                              |
| Inventario SAP                 | <br>CALCULATE(<br>    MAX('Inventarios_Molino_MBEW'[LBKUM]),<br>    FILTER(<br>        'Inventarios_Molino_MBEW',<br>        'Inventarios_Molino_MBEW'[MATNR] = 'Confiabilidad de Inventarios'[Codigo de Material]<br>    )<br>)<br>                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                               |
| Kilos Última Fecha             | <br>VAR FechaFinal =<br>    CALCULATE (<br>        MAX ( 'Tabla_Encolante_Convertido'[Date] ),<br>        FILTER (<br>            'Tabla_Encolante_Convertido',<br>            [Kilos Encolante] > 1 \|\|<br>            [Kilos Barrerador] > 1 \|\|<br>            [Kilos Retentivo 6226] > 1 \|\|<br>            [Kilos OBA 1540] > 1 \|\|<br>            [Kilos BLEACH] > 1 \|\|<br>            [Kilos Fixer 2960] > 1 \|\|<br>            [Kilos Fixer 2020] > 1 \|\|<br>            [Kilos Almidón de Maíz] > 1 \|\|<br>            [Kilos Coagulante] > 1 \|\|<br>            [Kilos Clean 2000] > 1 \|\|<br>            [Kilos FLOC 61100] > 1 \|\|<br>            [Kilos Pegamento] > 1 \|\|<br>            [Kilos Carbonato] > 1 \|\|<br>            [Kilos RC 8181] > 1<br>        )<br>    )<br><br>RETURN<br>SWITCH (<br>    TRUE(),<br><br>    'Confiabilidad de Inventarios'[Codigo de Material] = 110000020524,<br>        CALCULATE (<br>            SUM ( 'Tabla_Encolante_Convertido'[Kilos Encolante] ),<br>            'Tabla_Encolante_Convertido'[Date] = FechaFinal<br>        ),<br><br>    'Confiabilidad de Inventarios'[Codigo de Material] = 110000020527,<br>        CALCULATE (<br>            SUM ( 'Tabla_Encolante_Convertido'[Kilos Barrerador] ),<br>            'Tabla_Encolante_Convertido'[Date] = FechaFinal<br>        ),<br><br>    'Confiabilidad de Inventarios'[Codigo de Material] = 110000020530,<br>        CALCULATE (<br>            SUM ( 'Tabla_Encolante_Convertido'[Kilos Retentivo 6226] ),<br>            'Tabla_Encolante_Convertido'[Date] = FechaFinal<br>        ),<br><br>    'Confiabilidad de Inventarios'[Codigo de Material] = 110000020627,<br>        CALCULATE (<br>            SUM ( 'Tabla_Encolante_Convertido'[Kilos OBA 1540] ),<br>            'Tabla_Encolante_Convertido'[Date] = FechaFinal<br>        ),<br><br>    'Confiabilidad de Inventarios'[Codigo de Material] = 110000021414,<br>        CALCULATE (<br>            SUM ( 'Tabla_Encolante_Convertido'[Kilos BLEACH] ),<br>            'Tabla_Encolante_Convertido'[Date] = FechaFinal<br>        ),<br><br>    -- Fixer 2960<br>    'Confiabilidad de Inventarios'[Codigo de Material] = 110000023718,<br>        CALCULATE (<br>            SUM ( 'Tabla_Encolante_Convertido'[Kilos Fixer 2960] ),<br>            'Tabla_Encolante_Convertido'[Date] = FechaFinal<br>        ),<br><br>    -- Fixer 2020<br>    'Confiabilidad de Inventarios'[Codigo de Material] = 110000023719,<br>        CALCULATE (<br>            SUM ( 'Tabla_Encolante_Convertido'[Kilos Fixer 2020] ),<br>            'Tabla_Encolante_Convertido'[Date] = FechaFinal<br>        ),<br><br>    'Confiabilidad de Inventarios'[Codigo de Material] = 110000020522,<br>        CALCULATE (<br>            SUM ( 'Tabla_Encolante_Convertido'[Kilos Almidón de Maíz] ),<br>            'Tabla_Encolante_Convertido'[Date] = FechaFinal<br>        ),<br><br>    'Confiabilidad de Inventarios'[Codigo de Material] = 110000021697,<br>        CALCULATE (<br>            SUM ( 'Tabla_Encolante_Convertido'[Kilos Coagulante] ),<br>            'Tabla_Encolante_Convertido'[Date] = FechaFinal<br>        ),<br><br>    'Confiabilidad de Inventarios'[Codigo de Material] = 110000020528,<br>        CALCULATE (<br>            SUM ( 'Tabla_Encolante_Convertido'[Kilos FLOC 61100] ),<br>            'Tabla_Encolante_Convertido'[Date] = FechaFinal<br>        ),<br><br>    'Confiabilidad de Inventarios'[Codigo de Material] = 110000020545,<br>        CALCULATE (<br>            SUM ( 'Tabla_Encolante_Convertido'[Kilos Clean 2000] ),<br>            'Tabla_Encolante_Convertido'[Date] = FechaFinal<br>        ),<br><br>    'Confiabilidad de Inventarios'[Codigo de Material] = 110000022058,<br>        CALCULATE (<br>            SUM ( 'Tabla_Encolante_Convertido'[Kilos Pegamento] ),<br>            'Tabla_Encolante_Convertido'[Date] = FechaFinal<br>        ),<br><br>    'Confiabilidad de Inventarios'[Codigo de Material] = 110000016545,<br>        CALCULATE (<br>            SUM ( 'Tabla_Encolante_Convertido'[Kilos Carbonato] ),<br>            'Tabla_Encolante_Convertido'[Date] = FechaFinal<br>        ),<br><br>    'Confiabilidad de Inventarios'[Codigo de Material] = 110000026364,<br>        CALCULATE (<br>            SUM ( 'Tabla_Encolante_Convertido'[Kilos RC 8181] ),<br>            'Tabla_Encolante_Convertido'[Date] = FechaFinal<br>        ),<br><br>    BLANK ()<br>)<br> |
| Diferencia Inventario          | <br>VAR SAP  = 'Confiabilidad de Inventarios'[Inventario SAP]<br>VAR Real = 'Confiabilidad de Inventarios'[Kilos Última Fecha]<br>RETURN<br>IF (<br>    ISBLANK(SAP) \|\| ISBLANK(Real),<br>    BLANK(),<br>    Real - SAP<br>)<br>                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                |
| % de Confiabilidad             | <br>VAR SAP = 'Confiabilidad de Inventarios'[Inventario SAP]<br>VAR Real = 'Confiabilidad de Inventarios'[Kilos Última Fecha]<br>VAR Diferencia = ABS(Real - SAP)<br>RETURN<br>SWITCH(<br>    TRUE(),<br>    ISBLANK(SAP) && ISBLANK(Real), BLANK(),<br>    SAP = 0 && Real > 0, 0,<br>    SAP = 0 && Real = 0, 1,<br>    ISBLANK(Real), BLANK(),<br>    TRUE(), 1 - (Diferencia / SAP)<br>)<br>                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                   |
